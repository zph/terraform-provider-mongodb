{
  "provider": {
    "mongodb": [
      {
        "alias": "mongos_0",
        "auth_database": "admin",
        "direct": false,
        "host": "mongos1",
        "password": "pass",
        "port": "27017",
        "retrywrites": true,
        "ssl": false,
        "username": "admin"
      },
      {
        "alias": "mongos_1",
        "auth_database": "admin",
        "direct": false,
        "host": "mongos2",
        "password": "pass",
        "port": "27017",
        "retrywrites": true,
        "ssl": false,
        "username": "admin"
      }
    ]
  },
  "resource": {
    "mongodb_db_role": {
      "mongos_0_role_AppRole": {
        "database": "admin",
        "name": "AppRole",
        "provider": "mongodb.mongos_0"
      },
      "mongos_1_role_AppRole": {
        "database": "admin",
        "name": "AppRole",
        "provider": "mongodb.mongos_1"
      }
    },
    "mongodb_db_user": {
      "mongos_0_user_appuser": {
        "auth_database": "admin",
        "depends_on": [
          "mongodb_db_role.mongos_0_role_AppRole"
        ],
        "name": "appuser",
        "password": "secret",
        "provider": "mongodb.mongos_0"
      },
      "mongos_1_user_appuser": {
        "auth_database": "admin",
        "depends_on": [
          "mongodb_db_role.mongos_1_role_AppRole"
        ],
        "name": "appuser",
        "password": "secret",
        "provider": "mongodb.mongos_1"
      }
    }
  },
  "terraform": {
    "required_providers": {
      "mongodb": {
        "source": "registry.terraform.io/zph/mongodb",
        "version": "9.9.9"
      }
    },
    "required_version": "\u003e= 1.7.5"
  }
}