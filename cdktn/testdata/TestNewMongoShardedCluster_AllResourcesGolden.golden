    "mongodb_shard": {
      "shard_shard01": {
        "hosts": [
          "s1m1:27018",
          "s1m2:27019",
          "s1m3:27020"
        ],
        "provider": "mongodb.mongos_0",
        "remove_timeout_secs": 300,
        "shard_name": "shard01"
      },
      "shard_shard02": {
        "hosts": [
          "s2m1:27018",
          "s2m2:27019",
          "s2m3:27020"
        ],
        "provider": "mongodb.mongos_0",
        "remove_timeout_secs": 300,
        "shard_name": "shard02"
      }
    },
    "mongodb_shard_config": {
      "csrs_config": {
        "chaining_allowed": true,
        "election_timeout_millis": 10000,
        "heartbeat_interval_millis": 1000,
        "heartbeat_timeout_secs": 10,
        "provider": "mongodb.configsvr_csrs_0",
        "shard_name": "csrs"
      },
      "shard01_config": {
        "chaining_allowed": true,
        "election_timeout_millis": 10000,
        "heartbeat_interval_millis": 1000,
        "heartbeat_timeout_secs": 10,
        "provider": "mongodb.shard_shard01_0",
        "shard_name": "shard01"
      },
      "shard02_config": {
        "chaining_allowed": true,
        "election_timeout_millis": 10000,
        "heartbeat_interval_millis": 1000,
        "heartbeat_timeout_secs": 10,
        "provider": "mongodb.shard_shard02_0",
        "shard_name": "shard02"
      }
    },
    "mongodb_shard_zone": {
      "shard01_US_East": {
        "depends_on": [
          "mongodb_shard.shard_shard01",
          "mongodb_shard.shard_shard02"
        ],
        "provider": "mongodb.mongos_0",
        "shard_name": "shard01",
        "zone": "US-East"
      },
      "shard02_US_West": {
        "depends_on": [
          "mongodb_shard.shard_shard01",
          "mongodb_shard.shard_shard02"
        ],
        "provider": "mongodb.mongos_0",
        "shard_name": "shard02",
        "zone": "US-West"
      }
    },
    "mongodb_zone_key_range": {
      "app_orders_US_East_0": {
        "depends_on": [
          "mongodb_shard_zone.shard01_US_East",
          "mongodb_shard_zone.shard02_US_West"
        ],
        "max": "{\"_id\":0}",
        "min": "{\"_id\":{\"$minKey\":1}}",
        "namespace": "app.orders",
        "provider": "mongodb.mongos_0",
        "zone": "US-East"
      },
      "app_orders_US_West_1": {
        "depends_on": [
          "mongodb_shard_zone.shard01_US_East",
          "mongodb_shard_zone.shard02_US_West"
        ],
        "max": "{\"_id\":{\"$maxKey\":1}}",
        "min": "{\"_id\":0}",
        "namespace": "app.orders",
        "provider": "mongodb.mongos_0",
        "zone": "US-West"
      }
    }
