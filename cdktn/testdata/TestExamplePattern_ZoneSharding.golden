  "resource": {
    "mongodb_shard": {
      "shard_shard01": {
        "hosts": [
          "shard01a.example.com:27018",
          "shard01b.example.com:27018",
          "shard01c.example.com:27018"
        ],
        "provider": "mongodb.mongos_0",
        "remove_timeout_secs": 300,
        "shard_name": "shard01"
      },
      "shard_shard02": {
        "hosts": [
          "shard02a.example.com:27018",
          "shard02b.example.com:27018",
          "shard02c.example.com:27018"
        ],
        "provider": "mongodb.mongos_0",
        "remove_timeout_secs": 300,
        "shard_name": "shard02"
      },
      "shard_shard03": {
        "hosts": [
          "shard03a.example.com:27018",
          "shard03b.example.com:27018",
          "shard03c.example.com:27018"
        ],
        "provider": "mongodb.mongos_0",
        "remove_timeout_secs": 300,
        "shard_name": "shard03"
      }
    },
    "mongodb_shard_config": {
      "configRS_config": {
        "chaining_allowed": true,
        "election_timeout_millis": 10000,
        "heartbeat_interval_millis": 1000,
        "heartbeat_timeout_secs": 10,
        "provider": "mongodb.configsvr_configRS_0",
        "shard_name": "configRS"
      },
      "shard01_config": {
        "chaining_allowed": true,
        "election_timeout_millis": 10000,
        "heartbeat_interval_millis": 1000,
        "heartbeat_timeout_secs": 10,
        "provider": "mongodb.shard_shard01_0",
        "shard_name": "shard01"
      },
      "shard02_config": {
        "chaining_allowed": true,
        "election_timeout_millis": 10000,
        "heartbeat_interval_millis": 1000,
        "heartbeat_timeout_secs": 10,
        "provider": "mongodb.shard_shard02_0",
        "shard_name": "shard02"
      },
      "shard03_config": {
        "chaining_allowed": true,
        "election_timeout_millis": 10000,
        "heartbeat_interval_millis": 1000,
        "heartbeat_timeout_secs": 10,
        "provider": "mongodb.shard_shard03_0",
        "shard_name": "shard03"
      }
    },
    "mongodb_shard_zone": {
      "shard01_US_East": {
        "depends_on": [
          "mongodb_shard.shard_shard01",
          "mongodb_shard.shard_shard02",
          "mongodb_shard.shard_shard03"
        ],
        "provider": "mongodb.mongos_0",
        "shard_name": "shard01",
        "zone": "US-East"
      },
      "shard02_US_West": {
        "depends_on": [
          "mongodb_shard.shard_shard01",
          "mongodb_shard.shard_shard02",
          "mongodb_shard.shard_shard03"
        ],
        "provider": "mongodb.mongos_0",
        "shard_name": "shard02",
        "zone": "US-West"
      },
      "shard03_Backup": {
        "depends_on": [
          "mongodb_shard.shard_shard01",
          "mongodb_shard.shard_shard02",
          "mongodb_shard.shard_shard03"
        ],
        "provider": "mongodb.mongos_0",
        "shard_name": "shard03",
        "zone": "Backup"
      },
      "shard03_US_East": {
        "depends_on": [
          "mongodb_shard.shard_shard01",
          "mongodb_shard.shard_shard02",
          "mongodb_shard.shard_shard03"
        ],
        "provider": "mongodb.mongos_0",
        "shard_name": "shard03",
        "zone": "US-East"
      }
    },
    "mongodb_zone_key_range": {
      "analytics_logs_Backup_2": {
        "depends_on": [
          "mongodb_shard_zone.shard01_US_East",
          "mongodb_shard_zone.shard02_US_West",
          "mongodb_shard_zone.shard03_Backup",
          "mongodb_shard_zone.shard03_US_East"
        ],
        "max": "{\"tenant\":{\"$maxKey\":1},\"timestamp\":{\"$maxKey\":1}}",
        "min": "{\"tenant\":{\"$minKey\":1},\"timestamp\":{\"$minKey\":1}}",
        "namespace": "analytics.logs",
        "provider": "mongodb.mongos_0",
        "zone": "Backup"
      },
      "app_db_orders_US_East_0": {
        "depends_on": [
          "mongodb_shard_zone.shard01_US_East",
          "mongodb_shard_zone.shard02_US_West",
          "mongodb_shard_zone.shard03_Backup",
          "mongodb_shard_zone.shard03_US_East"
        ],
        "max": "{\"_id\":0}",
        "min": "{\"_id\":{\"$minKey\":1}}",
        "namespace": "app_db.orders",
        "provider": "mongodb.mongos_0",
        "zone": "US-East"
      },
      "app_db_orders_US_West_1": {
        "depends_on": [
          "mongodb_shard_zone.shard01_US_East",
          "mongodb_shard_zone.shard02_US_West",
          "mongodb_shard_zone.shard03_Backup",
          "mongodb_shard_zone.shard03_US_East"
        ],
        "max": "{\"_id\":{\"$maxKey\":1}}",
        "min": "{\"_id\":0}",
        "namespace": "app_db.orders",
        "provider": "mongodb.mongos_0",
        "zone": "US-West"
      }
    }
  },
  "terraform": {
    "required_providers": {
      "mongodb": {
        "source": "registry.terraform.io/zph/mongodb",
        "version": "9.9.9"
      }
    },
    "required_version": "\u003e= 1.7.5"
  }
}